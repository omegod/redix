{
  "name": "redix",
  "productName": "Redix",
  "version": "0.1.0",
  "description": "Redix rebuilt with TypeScript and Electron",
  "main": "./out/main/main.js",
  "author": "caichenghu",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "package:mac": "npm run build && electron-builder --mac --arm64",
    "package:win": "npm run build && electron-builder --win --x64"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.1",
    "antd": "^6.3.6",
    "ioredis": "^5.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^24.9.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "electron": "^38.3.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  },
  "build": {
    "appId": "com.redix.app",
    "productName": "Redix",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "icon": "resources/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "resources/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "resources/icon.png",
      "uninstallerIcon": "resources/icon.png"
    }
  }
}
